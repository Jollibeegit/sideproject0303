@using SideProject0303.Models

@if (Open)
{
    <div class="modal-backdrop" @onclick="Close">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-title">@((Mode == "edit") ? "일정 수정" : "일정 등록")</div>

            <div class="form">
                <label>구분</label>
                <div class="seg">
                    <button class="@SegClass(CalendarEventType.Memo)" @onclick="() => Pick(CalendarEventType.Memo)">메모</button>
                    <button class="@SegClass(CalendarEventType.Anniversary)" @onclick="() => Pick(CalendarEventType.Anniversary)">기념일</button>
                    <button class="@SegClass(CalendarEventType.Schedule)" @onclick="() => Pick(CalendarEventType.Schedule)">일정</button>
                </div>

                <label>날짜</label>
                <input type="date" class="input" value="@dateValue" @onchange="OnDateChange" />

                <label>내용</label>
                <input class="input" placeholder="예: 영화 보기" @bind="title" />

                <label>메모(선택)</label>
                <textarea class="textarea" placeholder="내용을 입력하세요" @bind="body"></textarea>

                <div class="actions">
                    <button class="btn" @onclick="Close">취소</button>
                    <button class="btn primary" @onclick="Save">등록</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public string Mode { get; set; } = "create"; // create|edit
    [Parameter] public CalendarEventType SelectedType { get; set; } = CalendarEventType.Schedule;
    [Parameter] public DateOnly InitialDate { get; set; }

    [Parameter] public CalendarEventItem? Editing { get; set; }

    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<EventModalSaveRequest> OnSave { get; set; }

    DateOnly date;
    string title = "";
    string? body;

    string dateValue => $"{date:yyyy-MM-dd}";

    protected override void OnParametersSet()
    {
        date = InitialDate;

        if (Editing is not null && Mode == "edit")
        {
            SelectedType = Editing.Type;
            title = Editing.Title;
            body = Editing.Body;
            date = Editing.StartDate;
        }
        else
        {
            // create 모드 기본값
            if (string.IsNullOrWhiteSpace(title))
                title = "";
            body ??= "";
        }
    }

    void Pick(CalendarEventType t) => SelectedType = t;

    string SegClass(CalendarEventType t) => SelectedType == t ? "segbtn active" : "segbtn";

    async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    void OnDateChange(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
            date = d;
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(title))
            return;

        var req = new EventModalSaveRequest
        {
            Type = SelectedType,
            Date = date,
            Title = title.Trim(),
            Body = string.IsNullOrWhiteSpace(body) ? null : body.Trim()
        };

        await OnSave.InvokeAsync(req);
    }
}

<style>
    .modal-backdrop{
        position:fixed; inset:0; background:rgba(0,0,0,.55);
        display:flex; align-items:center; justify-content:center;
        z-index:9999;
    }
    .modal-card{
        width:520px; max-width:92vw;
        background:#0b1631; border:1px solid rgba(255,255,255,.1);
        border-radius:16px; padding:18px; color:#eaf0ff;
        box-shadow:0 16px 40px rgba(0,0,0,.35);
    }
    .modal-title{ font-size:18px; font-weight:900; margin-bottom:14px; }
    .form{ display:flex; flex-direction:column; gap:10px; }
    label{ font-size:13px; opacity:.8; }
    .input, .textarea{
        width:100%;
        padding:10px 12px;
        border-radius:10px;
        border:1px solid rgba(255,255,255,.15);
        background:rgba(0,0,0,.2);
        color:#fff;
    }
    .textarea{ min-height:110px; resize:vertical; }
    .seg{ display:flex; gap:8px; }
    .segbtn{
        flex:1;
        padding:10px 12px;
        border-radius:999px;
        border:1px solid rgba(255,255,255,.15);
        background:rgba(255,255,255,.06);
        color:#fff; cursor:pointer;
    }
    .segbtn.active{
        background:rgba(140,80,255,.25);
        border-color:rgba(140,80,255,.45);
    }
    .actions{ display:flex; justify-content:flex-end; gap:8px; margin-top:8px; }
    .btn{
        padding:10px 14px;
        border-radius:10px;
        border:1px solid rgba(255,255,255,.15);
        background:rgba(255,255,255,.08);
        color:#fff; cursor:pointer;
    }
    .btn.primary{
        background:rgba(140,80,255,.25);
        border-color:rgba(140,80,255,.45);
        font-weight:800;
    }
</style>