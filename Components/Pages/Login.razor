@page "/"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using SideProject0303
@using SideProject0303.Models
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>커플 캘린더</PageTitle>

<div class="login-page">
    <div class="login-card">
        <div class="login-icon">운진이학규</div>
        <h1>우리끼리 쓰는 캘린더</h1>
        <p class="login-subtitle">누구세요~?</p>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="login-error">@_error</div>
        }

        @if (_users.Count > 0)
        {
            <div class="profile-row">
                @foreach (var user in _users)
                {
                    <div class="profile-card-wrap">
                        <button type="button" class="profile-card" @onclick="() => Enter(user)">
                            <div class="profile-photo-area">
                                @if (!string.IsNullOrWhiteSpace(user.ProfileImageUrl))
                                {
                                    <img class="profile-photo" src="@user.ProfileImageUrl" alt="@user.DisplayName" />
                                }
                                else
                                {
                                    <span class="profile-photo-empty">📷</span>
                                }
                                <label class="photo-upload-btn" @onclick:stopPropagation>
                                    ✏️
                                    <InputFile OnChange="e => OnFileSelected(e, user.Id)" accept="image/*" style="display:none" />
                                </label>
                            </div>
                            <span class="profile-avatar">@user.DisplayName</span>
                        </button>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private string? _error;
    private List<User> _users = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _users = await db.Users.AsNoTracking()
                .OrderBy(u => u.Id)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            _error = $"유저 목록을 불러올 수 없습니다: {ex.Message}";
        }
    }

    private void Enter(User user)
    {
        Nav.NavigateTo($"/{user.Id}");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e, long userId)
    {
        try
        {
            var file = e.File;
            if (file.Size > 10 * 1024 * 1024)
            {
                _error = "이미지는 10MB 이하만 가능합니다.";
                return;
            }

            var resized = await file.RequestImageFileAsync("image/jpeg", 400, 400);
            using var ms = new MemoryStream();
            await resized.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            var dataUrl = $"data:image/jpeg;base64,{base64}";

            await using var db = await DbFactory.CreateDbContextAsync();
            var user = await db.Users.FirstOrDefaultAsync(u => u.Id == userId);
            if (user is not null)
            {
                user.ProfileImageUrl = dataUrl;
                await db.SaveChangesAsync();

                var local = _users.FirstOrDefault(u => u.Id == userId);
                if (local is not null)
                {
                    _users[_users.IndexOf(local)] = await db.Users.AsNoTracking().FirstAsync(u => u.Id == userId);
                }
            }

            _error = null;
        }
        catch (Exception ex)
        {
            _error = $"이미지 업로드 실패: {ex.Message}";
        }
    }
}
